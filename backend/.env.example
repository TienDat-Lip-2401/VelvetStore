# Port chạy local
PORT=5000

# Cấu hình kết nối MySQL Database (Clever Cloud hoặc Railway)
DB_HOST=your_db_host
DB_PORT=your_db_port
DB_USER=your_db_user
DB_PASS=your_db_pass
DB_NAME=your_db_name

# Cấu hình JWT Token bảo mật
JWT_SECRET=your_jwt_secret_key_2026
JWT_EXPIRES_IN=7d

# URL của Frontend sau khi deploy lên Vercel (để tránh lỗi CORS)
CLIENT_URL=https://your-frontend.vercel.app

# Cấu hình Cloudinary (Quản lý hình ảnh)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cấu hình cổng VNPay (Nếu có dùng)
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-frontend.vercel.app/vnpay-return

# API Key Google Gemini (Để kích hoạt Chatbot AI đầy đủ tính năng)
GEMINI_API_KEY=your_google_gemini_api_key
